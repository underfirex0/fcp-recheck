# --- Supabase (new project, per your choice of a standalone mini-app) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key, server-side only, never expose to the client

# --- Tavily (search layer) ---
# Single key:
TAVILY_API_KEY=tvly-xxxxx
# OR multiple keys (comma-separated, no spaces) to spread usage across several
# free-tier accounts (1,000 credits each) — the app automatically rotates to
# the next key when one runs out of credits. If TAVILY_API_KEYS is set, it
# takes priority over TAVILY_API_KEY.
# TAVILY_API_KEYS=tvly-key1,tvly-key2,tvly-key3

# --- Gemini (extraction + grounding layer) ---
# Option A: Vertex AI on your GCP project (uses your GCP credits)
GOOGLE_GENAI_USE_VERTEXAI=true
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
# Paste the ENTIRE downloaded service account JSON file content as one value
# (works on Vercel — no filesystem needed). Easiest way to set this correctly:
#   vercel env add GOOGLE_APPLICATION_CREDENTIALS_JSON production < path/to/key.json
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Option B: plain Gemini Developer API / AI Studio key instead of Vertex AI
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=AIzaSy...

# Optional model overrides (defaults shown)
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# GEMINI_PRO_MODEL=gemini-2.5-pro
