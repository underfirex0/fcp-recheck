# --- Supabase (new project, per your choice of a standalone mini-app) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key, server-side only, never expose to the client

# --- Tavily (search layer) ---
TAVILY_API_KEY=tvly-xxxxx

# --- Gemini (extraction layer) ---
# Option A: Vertex AI on your GCP project (uses your GCP credits)
GOOGLE_GENAI_USE_VERTEXAI=true
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
# When using Vertex AI, auth is via Application Default Credentials (ADC).
# Locally: run `gcloud auth application-default login`.
# On Vercel: set up a service account key and GOOGLE_APPLICATION_CREDENTIALS,
# or use Vercel's GCP Workload Identity Federation integration if available.

# Option B: plain Gemini Developer API / AI Studio key instead of Vertex AI
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=AIzaSy...

# Optional model overrides (defaults shown)
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# GEMINI_PRO_MODEL=gemini-2.5-pro
